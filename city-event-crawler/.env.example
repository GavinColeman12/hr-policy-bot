# =============================================================================
# City Event Crawler - Environment Configuration
# Copy this to .env and fill in your API keys
# =============================================================================

# --- Google / SerpAPI ---
# Get key at: https://serpapi.com/
SERPAPI_KEY=

# --- Eventbrite ---
# Get token at: https://www.eventbrite.com/platform/api-keys
EVENTBRITE_TOKEN=

# --- Meetup ---
# API key for Meetup GraphQL API
MEETUP_API_KEY=

# --- Instagram (via Apify) ---
# Get token at: https://apify.com/
INSTAGRAM_APIFY_TOKEN=

# --- Reddit ---
# Create app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=CityEventCrawler/1.0

# --- Twitter / X ---
# Get bearer token at: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=

# --- Facebook ---
# Get token at: https://developers.facebook.com/
FACEBOOK_ACCESS_TOKEN=

# --- Ticketmaster ---
# Get key at: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# --- Yelp ---
# Get key at: https://www.yelp.com/developers/
YELP_API_KEY=

# --- Google Maps ---
# Get key at: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=

# --- Resident Advisor ---
RA_API_KEY=

# --- Operational Settings ---
CACHE_TTL_SECONDS=300
MAX_CONCURRENT_CRAWLERS=10
DEFAULT_RADIUS_KM=15
